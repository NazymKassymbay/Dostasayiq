{
  "info": {
    "name": "Dostasayiq API",
    "_postman_id": "dostasayiq-api-collection",
    "description": "Partner Finder Platform — Full API Collection\nBase URL: http://localhost:8000\n\nSetup:\n1. Register or Login first\n2. Copy the token from response\n3. The {{token}} variable is used automatically in all authenticated requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "paste_your_token_here",
      "type": "string"
    }
  ],
